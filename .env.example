# ==========================================
# ETORO SCRAPER CONFIGURATION
# ==========================================

# The Webhook URL for sending data to Google Sheets (ends with /exec)
WEBHOOK_URL=https://script.google.com/macros/s/your-webhook-url/exec

# Target number of historical trades to scrape (e.g., 500-1000)
HISTORY_TRADES_TARGET=1000

# ==========================================
# TRADER TARGETS
# ==========================================

# The username of a single eToro trader (Used for Mode 1)
TRADER_USERNAME=example_username

# Multiple trader usernames separated by commas, NO SPACES (Used for Mode 2)
MULTIPLE_TRADER_USERNAMES=trader1,trader2,trader3