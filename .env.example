# Copy this file to `.env` and fill in your values. `.env` is gitignored so secrets
# stay local. See README.md for context on each section.

# ==========================================
# ETORO SCRAPER CONFIGURATION
# ==========================================

# Google Apps Script Web App URL (ends with /exec). Only required if you choose a
# Google Sheets export option in the CLI; otherwise ignored.
WEBHOOK_URL=https://script.google.com/macros/s/your-webhook-url/exec

# Upper bound on closed-history rows per trader. Phase 4 paginates "Load More" until
# it hits this count or the button disappears.
HISTORY_TRADES_TARGET=1000

# ==========================================
# RATE LIMITING (Speed vs Block Risk) — REQUIRED
# ==========================================
# All four values are REQUIRED. The script refuses to start if any are missing,
# non-numeric, non-positive, or if MIN > MAX. Values are in milliseconds and act as
# min/max bounds for randomized waits — randomization is what makes the pacing look human.
#
# How to tune:
#   - Aggressive (small portfolio, low risk):  ASSET_GAP_MIN_MS=1500, ASSET_GAP_MAX_MS=2500
#   - Safe default:                            the recommended values below
#   - Cautious (after a block, or huge run):   ASSET 3000/5000, TRADER 10000/15000

# Phase 3: target gap between asset page loads, measured from the start of each cycle.
# Adaptive — if the page load itself already consumed the gap, only a 500ms floor is added.
ASSET_GAP_MIN_MS=2000
ASSET_GAP_MAX_MS=3500

# Between traders in multi-trader mode.
TRADER_GAP_MIN_MS=5000
TRADER_GAP_MAX_MS=8000

# ==========================================
# TRADER TARGETS
# ==========================================

# Used in single-trader mode. Profile URL on eToro is /people/<username>.
TRADER_USERNAME=example_username

# Used in multi-trader mode. Comma-separated, NO spaces between entries.
MULTIPLE_TRADER_USERNAMES=trader1,trader2,trader3