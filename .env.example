# Copy this file to `.env` and fill in your values. `.env` is gitignored so secrets
# stay local. See README.md for context on each section.

# ==========================================
# ETORO SCRAPER CONFIGURATION
# ==========================================

# Google Apps Script Web App URL (ends with /exec). Only required if you choose a
# Google Sheets export option in the CLI; otherwise ignored.
WEBHOOK_URL=https://script.google.com/macros/s/your-webhook-url/exec

# Upper bound on closed-history rows per trader. Phase 4 paginates "Load More" until
# it hits this count or the button disappears. Lower = fewer clicks = smaller request
# burst = less block risk (at the cost of less history). Raise it if you need more data
# and aren't getting blocked.
HISTORY_TRADES_TARGET=300

# ==========================================
# RATE LIMITING (Speed vs Block Risk) — REQUIRED
# ==========================================
# All six values are REQUIRED. The script refuses to start if any are missing,
# non-numeric, non-positive, or if a MIN > its MAX. Values are in milliseconds and act
# as min/max bounds for randomized waits — randomization is what makes pacing look human.
#
# The values below are the recommended block-resistant defaults. In testing, generous
# ASSET/TRADER gaps alone did NOT prevent blocks — the Phase 4 history burst and total
# volume matter most. So the primary levers are HISTORY_BATCH_DELAY and HISTORY_TRADES_TARGET
# (above), plus scraping in small batches (3-4 traders) and letting the IP rest between runs.
#
#   - Faster (only if you're never blocked):  ASSET 2000/3500, TRADER 5000/8000, HISTORY_BATCH 1500/3000
#   - Recommended:                            the values below
#   - Still blocked? raise HISTORY_BATCH to 5000/8000, lower HISTORY_TRADES_TARGET, rest the IP

# Phase 3: target gap between asset page loads, measured from the start of each cycle.
# Adaptive — if the page load itself already consumed the gap, only a 500ms floor is added.
ASSET_GAP_MIN_MS=6000
ASSET_GAP_MAX_MS=8000

# Between traders in multi-trader mode.
TRADER_GAP_MIN_MS=16000
TRADER_GAP_MAX_MS=20000

# Phase 4: pause between each history "Load More" click. This spreads the biggest request
# burst of a run, so it's the most effective knob against blocks. Raise it first if blocked.
HISTORY_BATCH_DELAY_MIN_MS=3000
HISTORY_BATCH_DELAY_MAX_MS=5000

# ==========================================
# TRADER TARGETS
# ==========================================

# Used in single-trader mode. Profile URL on eToro is /people/<username>.
TRADER_USERNAME=example_username

# Used in multi-trader mode. Comma-separated, NO spaces between entries.
MULTIPLE_TRADER_USERNAMES=trader1,trader2,trader3

# Optional TLS bypass for firewalls/VPNs that do TLS inspection. Set to 0 to disable
# certificate verification for outbound HTTPS (e.g. the Sheets webhook). Leave unset for
# normal, secure verification. Only needed if HTTPS requests fail with certificate errors.
# NODE_TLS_REJECT_UNAUTHORIZED=0